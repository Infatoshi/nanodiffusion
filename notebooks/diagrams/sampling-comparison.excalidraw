    {
      "id": "ddpm_method_box",
      "type": "rectangle",
      "x": 60,
      "y": 230,
      "width": 320,
      "height": 70,
      "strokeColor": "#9c36b5",
      "backgroundColor": "#f8f0fc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0
    },
    {
      "id": "ddpm_method",
      "type": "text",
      "x": 70,
      "y": 240,
      "width": 300,
      "height": 50,
      "text": "for t in reversed(range(100)):\n    pred_noise = model(x, t)\n    x = denoise_step(x, pred_noise, t)",
      "fontSize": 11,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "flow_method_box",
      "type": "rectangle",
      "x": 420,
      "y": 230,
      "width": 320,
      "height": 70,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0
    },
    {
      "id": "flow_method",
      "type": "text",
      "x": 430,
      "y": 240,
      "width": 300,
      "height": 50,
      "text": "for i in range(4):\n    velocity = model(x, t=i/4)\n    x = x + velocity * dt",
      "fontSize": 11,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "ddpm_stochastic",
      "type": "text",
      "x": 120,
      "y": 310,
      "width": 200,
