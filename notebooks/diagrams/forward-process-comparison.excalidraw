{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 250,
      "y": 20,
      "width": 300,
      "height": 35,
      "text": "Forward Process Comparison",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "ddpm_header",
      "type": "rectangle",
      "x": 50,
      "y": 70,
      "width": 300,
      "height": 40,
      "strokeColor": "#9c36b5",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "ddpm_header_text",
      "type": "text",
      "x": 130,
      "y": 80,
      "width": 140,
      "height": 20,
      "text": "DDPM (Complex)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "flow_header",
      "type": "rectangle",
      "x": 450,
      "y": 70,
      "width": 300,
      "height": 40,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "flow_header_text",
      "type": "text",
      "x": 520,
      "y": 80,
      "width": 160,
      "height": 20,
      "text": "Flow Matching (Simple)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "ddpm_formula_box",
      "type": "rectangle",
      "x": 50,
      "y": 120,
      "width": 300,
      "height": 80,
      "strokeColor": "#9c36b5",
      "backgroundColor": "#f8f0fc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0
    },
    {
      "id": "ddpm_formula",
      "type": "text",
      "x": 60,
      "y": 130,
      "width": 280,
      "height": 60,
      "text": "x_t = sqrt(alpha_bar[t]) * x0\n    + sqrt(1-alpha_bar[t]) * noise\n\nalpha_bar = cumulative product",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "flow_formula_box",
      "type": "rectangle",
      "x": 450,
      "y": 120,
      "width": 300,
      "height": 80,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0
    },
    {
      "id": "flow_formula",
      "type": "text",
      "x": 460,
      "y": 140,
      "width": 280,
      "height": 40,
      "text": "x_t = (1 - t) * noise + t * x0\n\nLinear interpolation!",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "ddpm_vis_label",
      "type": "text",
      "x": 150,
      "y": 215,
